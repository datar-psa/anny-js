{
  "hosting": {
    "site": "anny-js",
    "public": "dist-demo",
    "ignore": [
      "firebase.json", ".gitignore", ".npmignore",
      "**/node_modules/**", "**/.*"
    ],
    "headers": [
      {
        "source": "anny_model.bin",
        "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
      },
      {
        "source": "assets/**",
        "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
      }
    ],
    "rewrites": [
      { "source": "/",                  "destination": "/index.html" },
      { "source": "/demo",              "destination": "/anim.html" },
      { "source": "/demo/mediapipe",    "destination": "/live.html" },
      { "source": "/live",              "destination": "/live.html" },
      { "source": "/demo/video",        "destination": "/video.html" },
      { "source": "/video",             "destination": "/video.html" }
    ]
  }
}
