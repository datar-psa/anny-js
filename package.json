{
  "name": "anny-js",
  "version": "0.0.3",
  "description": "Browser-native JavaScript runtime for Naver's Anny parametric 3D body model (Apache 2.0): forward kinematics + linear blend skinning, parity-tested against Python anny, plus a MediaPipe Pose + Hand driver for 163-bone live animation.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./anny": {
      "import": "./dist/anny/index.js",
      "types": "./dist/anny/index.d.ts"
    },
    "./mediapipe": {
      "import": "./dist/mediapipe/index.js",
      "types": "./dist/mediapipe/index.d.ts"
    }
  },
  "files": [
    "dist",
    "assets",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "build:demo": "vite build",
    "dev": "tsc --watch",
    "check": "tsc --noEmit -p tsconfig.check.json",
    "test": "bun test",
    "demo": "vite"
  },
  "keywords": [
    "anny",
    "body-model",
    "skinning",
    "lbs",
    "forward-kinematics",
    "mediapipe",
    "pose",
    "avatar",
    "3d",
    "webgl",
    "browser",
    "animation"
  ],
  "homepage": "https://clad.you",
  "repository": {
    "type": "git",
    "url": "https://github.com/datar-psa/anny-js.git"
  },
  "bugs": {
    "url": "https://github.com/datar-psa/anny-js/issues"
  },
  "license": "Apache-2.0",
  "devDependencies": {
    "@mediapipe/tasks-vision": "0.10.14",
    "@types/bun": "^1.1.0",
    "playwright": "^1.60.0",
    "typescript": "^5.4.0",
    "vite": "^8.0.14"
  }
}
